# Root environment variables (for reference - server uses its own .env)
# Copy server/.env.example to server/.env and configure

# Server
PORT=5000
MONGODB_URI=mongodb://localhost:27017/intro-internship
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Admin credentials (auto-seeded on first run)
ADMIN_EMAIL=admin@introinternship.com
ADMIN_PASSWORD=admin123

# Twilio (SMS OTP - optional, OTP logs to console in dev)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# Nodemailer (Email OTP - optional, OTP logs to console in dev)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173
